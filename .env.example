# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=         # server only

NEXT_PUBLIC_GOOGLE_PLACES_KEY=     # browser-restricted (Autocomplete only, domain-locked)
GOOGLE_PLACES_SERVER_KEY=          # server only (Places Details)

NEXT_PUBLIC_MAPBOX_TOKEN=          # restrict to your domain in Mapbox dashboard

NEXT_PUBLIC_APP_URL=https://numazu-tabemono.vercel.app
